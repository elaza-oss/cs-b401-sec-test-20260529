# B4-01 PoC: .envrc canary (direnv)
# This tests whether Cloud Shell has direnv installed and auto-loads .envrc
# from the workspace directory set by cloudshell_workspace parameter.
#
# ETHICAL BOUNDS: Only writes a local canary file. No exfiltration.

echo "B4-01-ENVRC-CANARY: .envrc from repo executed at $(date -u +%Y-%m-%dT%H:%M:%SZ)" > /tmp/b4-01-envrc-canary.txt
echo "B4-01-ENVRC-CANARY: USER=$USER HOME=$HOME PWD=$PWD" >> /tmp/b4-01-envrc-canary.txt
